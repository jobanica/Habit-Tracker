# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or real secrets to git.
# All of these are read server-side only (except NEXT_PUBLIC_APP_URL).
# ---------------------------------------------------------------------------

# Xendit — https://dashboard.xendit.co/settings/developers#api-keys
# Use a TEST secret key (xnd_development_...) while testing.
XENDIT_SECRET_KEY=

# Xendit webhook verification token — Dashboard > Settings > Webhooks.
# Sent by Xendit in the `x-callback-token` header on every callback.
XENDIT_CALLBACK_TOKEN=

# Resend email delivery — https://resend.com/api-keys
# Server-side only. Create the key in the Resend dashboard.
RESEND_API_KEY=
# The "from" address. Must be on a domain you've verified in Resend, e.g.
# "Habit Tracker <no-reply@yourdomain.com>". For quick testing without a domain,
# use "onboarding@resend.dev" (Resend only delivers those to your own account email).
RESEND_FROM_EMAIL=

# Supabase — Project Settings > API
SUPABASE_URL=
# SERVICE ROLE key (secret, bypasses RLS). Server-side only. Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of the deployed app, no trailing slash.
# Local: http://localhost:3000  |  Prod: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
